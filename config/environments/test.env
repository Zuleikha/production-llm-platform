# Committed, NON-SECRET defaults for the `test` profile.
# Loaded automatically when ENVIRONMENT=test (used by the pytest suite).
ENVIRONMENT=test
SERVICE_NAME=api
API_HOST=127.0.0.1
API_PORT=8000
DEBUG=false
LOG_LEVEL=WARNING
LOG_FORMAT=json

# --- Stage 8 security (ADR 0019) — OBVIOUSLY-FAKE, TEST-ONLY credentials ---
# NOT a real key. The raw key is the fixed test value `test-key-not-a-real-secret`
# (see tests/fakes.py::TEST_API_KEY); the hash below is HMAC-SHA256(pepper, key)
# and the pepper is an equally-fake test-only value. Committed so the
# authenticated chat endpoint is exercisable in the hermetic suite and the
# test-profile container. See .gitleaks.toml for the scanning allowlist.
API_KEYS=test-principal:231965b3b3f3d6030b500d21b1984e72dbba04d4af29ceacae9bb3a1ee435034
API_KEY_HASH_SECRET=test-pepper-not-a-real-secret
