# Committed, NON-SECRET defaults for the `prod` profile.
# Loaded automatically when ENVIRONMENT=prod.
# Secrets (DATABASE_URL, REDIS_URL, etc.) are injected via the OS environment
# at deploy time — they MUST NOT appear in this file.
ENVIRONMENT=prod
SERVICE_NAME=api
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=false
LOG_LEVEL=INFO
LOG_FORMAT=json
