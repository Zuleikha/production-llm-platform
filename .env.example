# ---------------------------------------------------------------------------
# .env.example — copy to `.env` for local overrides:  cp .env.example .env
#
# Precedence (highest first):
#   1. real OS environment variables (what Docker / CI inject)
#   2. .env               (your local, git-ignored overrides)
#   3. config/environments/<ENVIRONMENT>.env   (committed, non-secret defaults)
#
# NEVER put real secrets in committed files. Secrets are injected via the OS
# environment (Docker Compose `environment:` / CI secrets) — see docs/coding-standards.md.
# ---------------------------------------------------------------------------

# Selects which profile file is loaded from config/environments/. One of: dev | test | prod
ENVIRONMENT=dev

# --- Service / API ---
SERVICE_NAME=api
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=false

# --- Logging ---
LOG_LEVEL=INFO
LOG_FORMAT=json          # json | console

# --- Datastore connection strings ---
# Pooled at startup and probed by /ready (ADR 0005). Values below are safe local
# dev placeholders, NOT production secrets.
#
# Leave a URL unset and that store reports `not_configured` and is never dialled
# — which is how the test suite stays hermetic. Under ENVIRONMENT=prod all three
# are MANDATORY: the service refuses to boot without them, rather than silently
# reporting itself ready with no database.
#
# The hostnames below are Compose service names; use localhost when running the
# API outside the stack (`uv run uvicorn ...`) against `docker compose up`.
DATABASE_URL=postgresql://platform:platform@postgres:5432/platform
REDIS_URL=redis://redis:6379/0
QDRANT_URL=http://qdrant:6333

# --- Datastore pooling (ADR 0005) ---
# DB_POOL_MIN_SIZE=1
# DB_POOL_MAX_SIZE=10
# REDIS_POOL_MAX_CONNECTIONS=10
# QDRANT_POOL_MAX_CONNECTIONS=10
# DATASTORE_CONNECT_TIMEOUT_SECONDS=5.0
# DATASTORE_PROBE_TIMEOUT_SECONDS=2.0
