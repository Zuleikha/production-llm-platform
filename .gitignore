# --- Python ---
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
*.so

# --- Virtual environments / uv ---
.venv/
venv/
# uv.lock IS committed on purpose (reproducible installs) — do not ignore it.

# --- Test / coverage / type caches ---
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml

# --- Environment / secrets ---
.env
.env.*
!.env.example
!config/environments/*.env

# --- IDE / editor ---
.idea/
.vscode/
*.swp
*~

# --- OS ---
.DS_Store
Thumbs.db

# --- Docker / local data volumes ---
*.pid
# Ignore local data dirs (e.g. Docker volume mounts) but NOT the RAG corpus: it is
# source, not a volume — read by the ingestion tests, copied into the image, and
# required to ingest (Stage 4). `data/*` (not `data/`) so git can descend and the
# negations below take effect; a bare `data/` would block re-inclusion entirely.
data/*
!data/README.md
!data/corpus/
docs/decisions/auto-changes.log
